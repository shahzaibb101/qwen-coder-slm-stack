# --- split mode: point the local gateway at the remote vLLM pod -------------
# RunPod HTTP proxy example: https://<pod-id>-8000.proxy.runpod.net/v1
# Full-stack mode (gpu profiles): leave the default.
VLLM_API_BASE=http://vllm:8000/v1

# Gateway auth (clients send this as the Bearer key)
LITELLM_MASTER_KEY=sk-demo-1234

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=admin

# Model served by the gpu profiles. Note: the 3B checkpoint is Qwen Research
# License (non-commercial); 1.5B is Apache-2.0 — see README "Known constraints".
MODEL_ID=Qwen/Qwen2.5-Coder-3B

# Only needed for gated/private HF models
HUGGING_FACE_HUB_TOKEN=
